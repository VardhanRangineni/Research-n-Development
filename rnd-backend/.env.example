# ─────────────────────────────────────────────────────────────────────────────
# Production environment template for rnd-backend
#
# HOW TO USE
#   Copy this file to /etc/rnd/backend.env on the server and fill in real values.
#   Never commit a file with real credentials to version control.
#   Load into the process via systemd EnvironmentFile= (see DEPLOYMENT.md §7).
# ─────────────────────────────────────────────────────────────────────────────

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Server port ───────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (MySQL) ──────────────────────────────────────────────────────────
# Do NOT include createDatabaseIfNotExist in production — create the DB manually first.
DB_URL=jdbc:mysql://localhost:3306/rnd_db?serverTimezone=UTC&useSSL=true&requireSSL=true
DB_USERNAME=root
DB_PASSWORD=root

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your actual frontend domain. Use same-origin (Nginx reverse proxy) to avoid CORS entirely.
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── First-deployment user seeding ────────────────────────────────────────────
# Set APP_SEED_DEFAULT_USERS_ENABLED=true ONLY on the very first deployment
# to create the initial HEAD user. Switch back to false and restart after login.
APP_SEED_DEFAULT_USERS_ENABLED=false
APP_HEAD_EMAIL=vardhan.r@medplusindia.com
APP_HEAD_USERNAME=Vardhan R
APP_HEAD_PASSWORD=Admin@123
