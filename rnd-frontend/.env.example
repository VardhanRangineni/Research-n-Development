# Copy this file to .env.local for local development.
# For production, copy to .env.production and set appropriate values.
# Never commit .env.local or .env.production to version control.

# API base URL:
# - Leave empty ("") when the frontend and backend share the same origin
#   (recommended: serve both through an nginx reverse proxy on the same domain).
# - Set to the full backend URL only when running on separate origins.
VITE_API_BASE_URL=
